FROM python:3.12-slim
WORKDIR /app
RUN pip install --no-cache-dir \
    flask==3.0.3 \
    boto3==1.34.34 \
    cryptography==42.0.5 \
    numpy==1.26.4 \
    gunicorn==22.0.0
COPY lambdas/ lambdas/
COPY aggregation/ aggregation/
COPY server.py .
CMD ["gunicorn", "--bind", "0.0.0.0:8080", "--workers", "2", "--timeout", "120", "server:app"]
